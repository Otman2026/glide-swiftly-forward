{
  "name": "saifo-transport-erp-desktop",
  "productName": "SAIFO TRANSPORT ERP",
  "version": "1.0.1",
  "description": "SAIFO TRANSPORT ERP — Desktop",
  "author": "SAIFO Transport",
  "repository": {
    "type": "git",
    "url": "https://github.com/Otman2026/glide-swiftly-forward.git"
  },
  "main": "main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.saifo.transport.erp",
    "productName": "SAIFO TRANSPORT ERP",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "icon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "icon.ico",
      "artifactName": "SAIFO-TRANSPORT-ERP-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SAIFO TRANSPORT ERP"
    }
  }
}
